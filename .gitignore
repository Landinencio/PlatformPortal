# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
node_modules

# local debug artifacts and ad-hoc exports
/debug_output*.txt
/debug_*.json
/jobs.json
/projects.json
/jobs_page_*.json
/pipeline_jobs*.json
/*.code-workspace
/scripts/debug/.artifacts/

# build artifacts
/.tmp/

# helm chart vendored dependencies (resolved via `helm dependency build` in CI)
/.helm/charts/
/.helm/Chart.lock

# ad-hoc ops scripts / artifacts for the cicd-gitops migration (not app code)
/ops/cicd-gitops/
